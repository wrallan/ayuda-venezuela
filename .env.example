# Copia este archivo como .env.local para desarrollo, y configura las
# mismas variables en Vercel (Project Settings > Environment Variables)
# para producción.

# --- Supabase ---
# Los encuentras en: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-clave-anon-publica

# CRÍTICO: esta clave NUNCA debe llevar el prefijo NEXT_PUBLIC_ ni
# exponerse al navegador. Solo se usa en rutas de servidor (app/api/**).
SUPABASE_SERVICE_ROLE_KEY=tu-clave-service-role-secreta

# --- Sesión de administrador ---
# Cadena aleatoria de al menos 32 caracteres, usada para firmar el JWT
# de sesión del admin. Genera una nueva y única para tu proyecto, por
# ejemplo con: openssl rand -base64 48
SESSION_SECRET=cambia-esto-por-una-cadena-aleatoria-larga-y-unica
